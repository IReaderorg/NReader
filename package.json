{
  "name": "ireader-next",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @ireader/backend dev & sleep 2 && pnpm --filter @ireader/frontend dev",
    "build": "pnpm --filter @ireader/backend build && pnpm --filter @ireader/frontend build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter @ireader/e2e test",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ws": "^8.21.0"
  }
}
